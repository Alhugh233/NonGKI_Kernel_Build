CONFIG_ENV=Profiles/jason_mokee.env

DEVICE_NAME=xiaomi_mi_note_3
DEVICE_CODENAME=jason

CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-
EXTRA_CMDS:HOSTCC=gcc

KERNEL_SOURCE=https://github.com/Alhugh233/android_kernel_xiaomi_sdm660
KERNEL_BRANCH=mkq-mr1
CLANG_SOURCE=https://github.com/repinger/android_clang-12.git
CLANG_BRANCH=main

GCC_GNU=true
GCC_64_SOURCE=
GCC_64_BRANCH=
GCC_32_SOURCE=
GCC_32_BRANCH=

DEFCONFIG_SOURCE=
DEFCONFIG_NAME=jason_defconfig

KERNELSU_SOURCE=https://raw.githubusercontent.com/ReSukiSU/ReSukiSU/main/kernel/setup.sh
KERNELSU_BRANCH=main
KERNELSU_NAME=KernelSU

SUSFS_ENABLE=false
SUSFS_FIXED=false

AK3_SOURCE=https://github.com/osm0sis/AnyKernel3.git
AK3_BRANCH=master

BOOT_SOURCE=

LXC_ENABLE=false

HAVE_NO_DTBO=false
ROM_TEXT=MOKEE
